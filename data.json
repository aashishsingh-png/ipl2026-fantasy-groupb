// floor all to 0
const getBase = (player, match) => {
  const v = RAW[player]?.[match];
  if (v === undefined || v === null) return 0;
  if (typeof v === "number") return Math.max(0, Math.round(v));
  return 0;
};
const getNote = (player, match) => RAW[player]?.["note"+match.slice(1)] || (getBase(player,match)>0?"":"Not in XI");

// ═══════════════════════════════════════════════════════════════
// TEAM DEFINITIONS
// ═══════════════════════════════════════════════════════════════
const TEAMS = {
  T1:{name:"T1 Nishant & Mainak",c:"Finn Allen",vc:"Hardik Pandya",
    pl:["Finn Allen","Hardik Pandya","Sunil Narine","Vaibhav Arora","Varun Chakaravarthy","Mohammed Siraj","Quinton de Kock","Marco Jansen","Kuldeep Yadav","Prasidh Krishna","Priyansh Arya"]},
  T2:{name:"T2 Smatish & Swapnesh",c:"Ishan Kishan",vc:"Axar Patel",
    pl:["Ishan Kishan","Rohit Sharma","Ajinkya Rahane","Bhuvneshwar Kumar","Shivam Dube","Jasprit Bumrah","Axar Patel","Jacob Bethell","Will Jacks","Ashwani Kumar","Jofra Archer"]},
  T3:{name:"T3 Dhruv & Vishal",c:"Shubman Gill",vc:"Yashasvi Jaiswal",
    pl:["Angkrish Raghuvanshi","Yashasvi Jaiswal","Abhishek Sharma","Mohammed Shami","Avesh Khan","Nitish Kumar Reddy","Harshal Patel","Pathum Nissanka","Azmatullah Omarzai","T Natarajan","Shubman Gill"]},
  T4:{name:"T4 Arif & Shailesh",c:"KL Rahul",vc:"Ruturaj Gaikwad",
    pl:["Rinku Singh","Dhruv Jurel","Ruturaj Gaikwad","KL Rahul","Aiden Markram","Rishabh Pant","Dewald Brevis","Tim David","Prabhsimran Singh","Jason Holder","Harsh Dubey"]},
  T5:{name:"T5 Rahul & Sahil M",c:"Virat Kohli",vc:"Sai Sudharsan",
    pl:["Virat Kohli","Ravindra Jadeja","Suryakumar Yadav","Riyan Parag","Khaleel Ahmed","Sai Sudharsan","Josh Hazlewood","Marcus Stoinis","Mukesh Kumar","Digvesh Singh Rathi","Karun Nair"]},
  T6:{name:"T6 Sanidhya & Aashish & Sahil Tagra",c:"Cameron Green",vc:"Sanju Samson",
    pl:["Ryan Rickelton","Romario Shepherd","Cameron Green","Heinrich Klaasen","Sanju Samson","Ayush Mhatre","Kagiso Rabada","Tristan Stubbs","Krunal Pandya","Washington Sundar"]},
  T7:{name:"T7 Ishaan & Mohit & Harshank",c:"Shreyas Iyer",vc:"Mitchell Marsh",
    pl:["Devdutt Padikkal","Ravi Bishnoi","Philip Salt","Matt Henry","Noor Ahmad","Mitchell Marsh","Nicholas Pooran","Shreyas Iyer","Yuzvendra Chahal","Abishek Porel","Shashank Singh"]},
  T8:{name:"T8 Abhishek & Jitesh & Girish",c:"Travis Head",vc:"Vaibhav Sooryavanshi",
    pl:["Vaibhav Sooryavanshi","Tilak Varma","Travis Head","Trent Boult","Shimron Hetmyer","Arshdeep Singh","Rashid Khan","Jos Buttler","Jitesh Sharma","Mitchell Santner","Nehal Wadhera"]},
};

const MLS = ["M1","M2","M3"];
const ML = {M1:"RCB vs SRH (28 Mar)",M2:"MI vs KKR (29 Mar)",M3:"RR vs CSK (30 Mar)"};
const COL = ["#1d9e75","#378add","#d85a30","#7f77dd","#ba7517","#d4537e","#3b6d11","#5f5e5a"];

const mlt = (p,t) => p===t.c?2:p===t.vc?1.5:1;
const pPts = (player,tk) => {
  const t=TEAMS[tk], m=mlt(player,t); let total=0; const pm={};
  MLS.forEach(match => {
    const base=getBase(player,match), pts=Math.round(base*m);
    pm[match]={base,pts}; total+=pts;
  });
  return {pm,total,m};
};
const tTotal = tk => TEAMS[tk].pl.reduce((s,p)=>s+pPts(p,tk).total,0);

// JSON builder
const buildJSON = () => {
  const out = {
    lastUpdated: new Date().toISOString(),
    scoringSystem: "Dream11 T20",
    matches: MLS.map(m=>ML[m]),
    teams: Object.keys(TEAMS)
      .map(k=>({k,tot:tTotal(k)}))
      .sort((a,b)=>b.tot-a.tot)
      .map(({k})=>{
        const t=TEAMS[k];
        return {
          teamId:k, teamName:t.name, captain:t.c, viceCaptain:t.vc,
          totalPoints:tTotal(k),
          players:[...t.pl]
            .map(p=>({p,...pPts(p,k)}))
            .sort((a,b)=>b.total-a.total)
            .map(({p,pm,total,m})=>({
              name:p,
              role:p===t.c?"Captain":p===t.vc?"Vice Captain":"Player",
              multiplier:m,
              M1_base:pm.M1.base, M1_pts:pm.M1.pts,
              M2_base:pm.M2.base, M2_pts:pm.M2.pts,
              M3_base:pm.M3.base, M3_pts:pm.M3.pts,
              totalPoints:total
            }))
        };
      })
  };
  return JSON.stringify(out,null,2);
};

const ranked = Object.keys(TEAMS).map(k=>({k,tot:tTotal(k)})).sort((a,b)=>b.tot-a.tot);
const maxT = ranked[0]?.tot||1;

export default function App() {
  const [view,setView] = useState("board");
  const [selT,setSelT] = useState("T1");
  const [selP,setSelP] = useState(null);
  const [copied,setCopied] = useState(false);

  const B=(lbl,act,fn,sm)=>(
    <button onClick={fn} style={{padding:sm?"3px 8px":"5px 12px",fontSize:sm?"11px":"12px",
      cursor:"pointer",borderRadius:"var(--border-radius-md)",
      border:`0.5px solid var(--color-border-${act?"primary":"tertiary"})`,
      background:act?"var(--color-background-secondary)":"transparent",
      color:"var(--color-text-primary)"}}>
      {lbl}
    </button>
  );

  const copyJSON=()=>{
    navigator.clipboard.writeText(buildJSON()).then(()=>{setCopied(true);setTimeout(()=>setCopied(false),2500);});
  };

  return (
    <div style={{fontFamily:"var(--font-sans)",padding:"0.5rem 0",color:"var(--color-text-primary)"}}>
      <div style={{display:"flex",gap:"6px",flexWrap:"wrap",marginBottom:"12px"}}>
        {B("🏆 Leaderboard",view==="board",()=>setView("board"))}
        {B("📊 Player Breakdown",view==="players",()=>setView("players"))}
        {B("{} Export JSON",view==="json",()=>setView("json"))}
      </div>

      {/* LEADERBOARD */}
      {view==="board"&&(
        <div>
          <p style={{fontSize:"12px",color:"var(--color-text-secondary)",marginBottom:"14px"}}>
            3 matches · Dream11 T20 system · C=2× · VC=1.5× · ESPN verified scorecards
          </p>
          {ranked.map(({k,tot},i)=>{
            const t=TEAMS[k],pct=Math.round((tot/maxT)*100);
            return(
              <div key={k} style={{marginBottom:"14px"}}>
                <div style={{display:"flex",justifyContent:"space-between",fontSize:"13px",marginBottom:"3px"}}>
                  <span><span style={{fontWeight:500,color:COL[i],marginRight:"6px"}}>#{i+1}</span><span style={{fontWeight:500}}>{t.name}</span></span>
                  <span style={{fontWeight:500,fontSize:"14px"}}>{tot} pts</span>
                </div>
                <div style={{height:"10px",borderRadius:"5px",background:"var(--color-background-secondary)",overflow:"hidden"}}>
                  <div style={{height:"100%",width:`${pct}%`,background:COL[i],borderRadius:"5px"}}/>
                </div>
                <div style={{fontSize:"10px",color:"var(--color-text-tertiary)",marginTop:"2px"}}>
                  C: {t.c} · VC: {t.vc}
                </div>
              </div>
            );
          })}
          <div style={{marginTop:"12px",padding:"10px",background:"var(--color-background-secondary)",borderRadius:"var(--border-radius-md)",fontSize:"11px",color:"var(--color-text-secondary)",lineHeight:"1.8"}}>
            <strong style={{color:"var(--color-text-primary)"}}>Dream11 T20 rules applied:</strong><br/>
            Bat: run+1, 4bonus+4, 6bonus+6, milestones(25/50/75/100), duck-2, SR≥10balls<br/>
            Bowl: dot+1, wkt+30, LBW/Bowled+8, 3W/4W/5W bonus, maiden+12, eco≥2ov<br/>
            Field: catch+8, 3catch-bonus+4, stumping+12, RO-direct+12, RO-indirect+6
          </div>
        </div>
      )}

      {/* PLAYER BREAKDOWN */}
      {view==="players"&&(
        <div>
          <div style={{display:"flex",gap:"5px",flexWrap:"wrap",marginBottom:"8px"}}>
            {Object.keys(TEAMS).map(k=>B(k,selT===k,()=>{setSelT(k);setSelP(null);},true))}
          </div>
          <div style={{fontSize:"13px",fontWeight:500,marginBottom:"2px"}}>{TEAMS[selT].name}</div>
          <div style={{fontSize:"11px",color:"var(--color-text-secondary)",marginBottom:"8px"}}>
            C: {TEAMS[selT].c} (2×) · VC: {TEAMS[selT].vc} (1.5×)
          </div>
          {selP&&(
            <div style={{padding:"10px",background:"var(--color-background-secondary)",borderRadius:"var(--border-radius-md)",marginBottom:"10px",fontSize:"11px",lineHeight:"1.7"}}>
              <strong style={{color:"var(--color-text-primary)"}}>{selP} — Calculation Breakdown</strong>
              {MLS.map(m=>{
                const note=getNote(selP,m),base=getBase(selP,m),{pm,m:mx}=pPts(selP,selT);
                return(<div key={m}><strong>{m}:</strong> {note||"Not in XI"} {base>0&&mx>1?`→ ×${mx} = ${pm[m].pts}pts`:base>0?`= ${base}pts`:""}</div>);
              })}
              <div style={{marginTop:"4px",color:"var(--color-text-tertiary)",cursor:"pointer",fontSize:"10px"}} onClick={()=>setSelP(null)}>✕ close</div>
            </div>
          )}
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:"12px"}}>
              <thead>
                <tr style={{borderBottom:"0.5px solid var(--color-border-secondary)"}}>
                  <th style={{textAlign:"left",padding:"5px 6px",fontWeight:500,color:"var(--color-text-secondary)"}}>Player</th>
                  {MLS.map(m=><th key={m} style={{textAlign:"right",padding:"5px 6px",fontWeight:500,color:"var(--color-text-secondary)",fontSize:"11px"}}>{m}</th>)}
                  <th style={{textAlign:"right",padding:"5px 6px",fontWeight:500,color:"var(--color-text-secondary)"}}>Total</th>
                </tr>
              </thead>
              <tbody>
                {[...TEAMS[selT].pl].map(p=>({p,...pPts(p,selT)})).sort((a,b)=>b.total-a.total).map(({p,pm,total,m:mx})=>{
                  const isC=p===TEAMS[selT].c,isVC=p===TEAMS[selT].vc;
                  return(
                    <tr key={p} onClick={()=>setSelP(selP===p?null:p)}
                      style={{borderBottom:"0.5px solid var(--color-border-tertiary)",cursor:"pointer",
                        background:selP===p?"var(--color-background-secondary)":"transparent"}}>
                      <td style={{padding:"6px 6px",whiteSpace:"nowrap",fontSize:"12px"}}>
                        {p}
                        {isC&&<span style={{marginLeft:"4px",fontSize:"9px",padding:"1px 4px",borderRadius:"3px",background:"var(--color-background-warning)",color:"var(--color-text-warning)",fontWeight:500}}>C 2×</span>}
                        {isVC&&<span style={{marginLeft:"4px",fontSize:"9px",padding:"1px 4px",borderRadius:"3px",background:"var(--color-background-info)",color:"var(--color-text-info)",fontWeight:500}}>VC 1.5×</span>}
                      </td>
                      {MLS.map(m=>(
                        <td key={m} style={{textAlign:"right",padding:"6px 6px",color:pm[m].pts>0?"var(--color-text-primary)":"var(--color-text-tertiary)"}}>
                          {pm[m].pts>0?<span title={`Base:${pm[m].base}${mx>1?` ×${mx}`:""}`}>{pm[m].pts}</span>:"—"}
                        </td>
                      ))}
                      <td style={{textAlign:"right",padding:"6px 6px",fontWeight:500}}>{total||"—"}</td>
                    </tr>
                  );
                })}
              </tbody>
              <tfoot>
                <tr style={{borderTop:"0.5px solid var(--color-border-secondary)",background:"var(--color-background-secondary)"}}>
                  <td colSpan={4} style={{padding:"6px 6px",fontWeight:500}}>Team Total</td>
                  <td style={{textAlign:"right",padding:"6px 6px",fontWeight:500,fontSize:"14px"}}>{tTotal(selT)}</td>
                </tr>
              </tfoot>
            </table>
          </div>
          <p style={{fontSize:"10px",color:"var(--color-text-tertiary)",marginTop:"6px"}}>Click any row to see full calculation</p>
        </div>
      )}

      {/* JSON EXPORT */}
      {view==="json"&&(
        <div>
          <div style={{display:"flex",gap:"8px",alignItems:"center",marginBottom:"10px"}}>
            <button onClick={copyJSON} style={{padding:"7px 16px",fontSize:"13px",cursor:"pointer",
              borderRadius:"var(--border-radius-md)",border:"0.5px solid var(--color-border-primary)",
              background:"var(--color-background-secondary)",color:"var(--color-text-primary)",fontWeight:500}}>
              {copied?"✅ Copied!":"📋 Copy JSON for GitHub"}
            </button>
          </div>
          <p style={{fontSize:"11px",color:"var(--color-text-secondary)",marginBottom:"8px"}}>
            Paste into your GitHub repo's <code style={{fontSize:"11px"}}>data.json</code> and commit. Teams ranked by total points.
          </p>
          <div style={{background:"var(--color-background-secondary)",borderRadius:"var(--border-radius-md)",padding:"12px",overflowX:"auto",maxHeight:"420px",overflowY:"auto"}}>
            <pre style={{fontSize:"10px",margin:0,whiteSpace:"pre-wrap",wordBreak:"break-word",color:"var(--color-text-primary)",lineHeight:"1.5"}}>
              {buildJSON()}
            </pre>
          </div>
        </div>
      )}
    </div>
  );
}
