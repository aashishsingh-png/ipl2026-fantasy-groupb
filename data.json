    // 4+6 = 10
    note3: "Announced+4 | Run-out indirect(Overton via Hetmyer→Jurel)+6 | =10"
  },
  "Arshdeep Singh":   {},
  "Rashid Khan":      {},
  "Jos Buttler":      {},
  "Jitesh Sharma": {
    // M1 RCB XI (WK): Bat 0(1) DUCK — 1b<10→no SR | WK catch: Abhishek Sharma (c†Jitesh b Duffy)
    M1: BAT(0,1,0,0,true) + FLD(1),
    // 4-2 = 2 | catch+8 = 10
    note1: "Bat 0(1) duck | WK catch Abhishek+8 | 2+8=10"
  },
  "Mitchell Santner": {},
  "Nehal Wadhera":    {},
