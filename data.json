  "Abishek Porel":    {},
  "Shashank Singh":   {},

  // ════════════════════════════════════════════
  // T8 — Abhishek & Jitesh & Girish  |  C: Travis Head  VC: Vaibhav Sooryavanshi
  // ════════════════════════════════════════════

  "Vaibhav Sooryavanshi": {
    // M3 RR XI: Bat 52(17) 4×4 5×6 SR=305.9>170+6 | milestone 50+:+8
