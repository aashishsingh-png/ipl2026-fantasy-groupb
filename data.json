// DREAM11 T20 SCORING — verified from dream11.com/fantasy-cricket/point-system
// ═══════════════════════════════════════════════════════════════
// BATTING: run+1, 4-bonus+4, 6-bonus+6, 25+:+4, 50+:+8, 75+:+12, 100+:+16
//          (highest milestone only, no stacking), duck:-2
//          SR(≥10 balls): >170:+6, 150.01-170:+4, 130-150:+2, 60-70:-2, 50-59.99:-4, <50:-6
// BOWLING: dot+1, wkt+30, LBW/bowled+8, 3W:+4, 4W:+8, 5W:+12, maiden+12
//          Eco(≥2 overs): <5:+6, 5-5.99:+4, 6-7:+2, 10-11:-2, 11.01-12:-4, >12:-6
// FIELDING: catch+8, 3-catch-bonus+4, stumping+12, RO-direct+12, RO-indirect+6
// OTHER: announced+4, impact-sub+4, C:×2, VC:×1.5

const SR = (r, b) => {
  if (b < 10) return 0;
  const s = (r / b) * 100;
  if (s > 170) return 6; if (s > 150) return 4; if (s >= 130) return 2;
  if (s >= 70) return 0; if (s >= 60) return -2; if (s >= 50) return -4;
  return -6;
};
const ECO = (r, o) => {
  if (o < 2) return 0;
  const e = r / o;
  if (e < 5) return 6; if (e < 6) return 4; if (e <= 7) return 2;
  if (e <= 10) return 0; if (e <= 11) return -2; if (e <= 12) return -4;
  return -6;
};
const MS = r => r >= 100 ? 16 : r >= 75 ? 12 : r >= 50 ? 8 : r >= 25 ? 4 : 0;

// bat(runs, balls, 4s, 6s, duck)  — +4 announced included
const BAT = (r, b, f4, s6, duck = false) =>
  4 + r + f4*4 + s6*6 + MS(r) + (duck ? -2 : 0) + SR(r, b);

// bowl(overs, runs, wkts, dots, maidens=0, lbwBowled=0) — +4 announced included
const BOWL = (o, r, w, d, m = 0, lb = 0) => {
  let p = 4 + d + w*30 + lb*8 + m*12;
  if (w >= 5) p += 12; else if (w >= 4) p += 8; else if (w >= 3) p += 4;
  return p + ECO(r, o);
};

// field(catches, stumpings, rodirect, roindirect)
const FLD = (c=0, st=0, rod=0, roi=0) =>
  c*8 + (c >= 3 ? 4 : 0) + st*12 + rod*12 + roi*6;

